{
  "name": "sizzler",
  "version": "1.0.0",
  "private": true,
  "description": "Sizzler — recipe storage & meal-planning PWA (React + Vite client, Express + Neon + Cloudinary server)",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"yellow,cyan\" \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "start": "node server/index.js",
    "build": "cd client && npm install && npm run icons && npm run build",
    "seed": "node server/seed.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
