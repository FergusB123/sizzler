# ── Sizzler server env (copy to .env at the repo root) ──
# Loaded by server/app.js via dotenv. Nothing here is exposed to the browser;
# the client only learns the VAPID *public* key + feature flags via /api/config.

# Neon Postgres — create a NEW database for Sizzler at neon.tech
DATABASE_URL=postgres://user:password@host/sizzler?sslmode=require

# Auth
JWT_SECRET=change_this_to_a_long_random_string

# Anthropic (reuse Botanica's key)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cloudinary unsigned upload (reuse Botanica's account + preset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Web Push (generate once with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Vercel Cron protection (optional; set to a random string in production)
CRON_SECRET=

# Optional real image generator (default = on-brand SVG placeholder)
# IMAGE_GEN_PROVIDER=stub
# IMAGE_GEN_API_KEY=

# Server
PORT=3011
NODE_ENV=development
