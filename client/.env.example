# ─────────────────────────────────────────────────────────────
# Sizzler environment
# Copy to `.env` and fill in. Anything VITE_* is exposed to the
# browser bundle — never put secret keys (Anthropic, service role)
# in a VITE_ var. Those live only in Supabase Edge Function secrets.
# ─────────────────────────────────────────────────────────────

# --- Client (safe to ship in the bundle) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public VAPID key for Web Push (the matching private key is a server secret).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# --- Server-only secrets (set via: supabase secrets set KEY=value) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:you@example.com
#
# Image generation is a single-file swap (see supabase/functions/generate-image).
# Leave unset to use the deterministic SVG placeholder generator.
# IMAGE_GEN_PROVIDER=stub        # stub | openai | replicate
# IMAGE_GEN_API_KEY=...
